<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ 需要声明前台服务类型 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- WakeLock：防止 CPU 休眠 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 申请忽略电池优化：弹出系统对话框让用户授权，避免国产 ROM 在息屏后杀后台 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 开机自启（需在系统设置中手动授权） -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        精确闹钟权限：
        Android 12（API 31）以下：SCHEDULE_EXACT_ALARM 默认授予
        Android 12+：用户需在"特殊应用权限"中手动开启"闹钟和提醒"
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Android 13+ 备用权限（不需要用户手动授权，降级精确度，但仍可触发） -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.TowerOpsApp"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.TowerLoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!--
            前台服务：
            - stopWithTask="false"：从最近任务划掉 APP 后服务不停止
            - foregroundServiceType="dataSync"：Android 14+ 必填
        -->
        <service
            android:name=".worker.MonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <!--
            开机自启接收器：
            - exported="true" 必须为 true，否则系统广播收不到
            - enabled="true" 确保默认启用
        -->
        <receiver
            android:name=".worker.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <!-- 标准开机广播 -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- 华为/HTC 快速启动 -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!--
            AlarmManager 触发接收器：
            - 接收 AlarmManager 的精确闹钟，立刻拿 WakeLock 再启动服务
            - exported="false"：只接收 APP 内部广播，不对外暴露
        -->
        <receiver
            android:name=".worker.AlarmReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="com.towerops.app.ALARM_TRIGGER" />
            </intent-filter>
        </receiver>

        <!--
            JobScheduler 保活兜底：
            - 系统级调度，不受国产 ROM 省电策略屏蔽
            - permission="android.permission.BIND_JOB_SERVICE" 是系统要求，必须加
        -->
        <service
            android:name=".worker.MonitorJobService"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE" />

    </application>

</manifest>
