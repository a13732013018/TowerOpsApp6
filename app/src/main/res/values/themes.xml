<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 专业蓝白主题 精致版 -->
    <style name="Theme.TowerOpsApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#2563EB</item>
        <item name="colorPrimaryDark">#1E3A8A</item>
        <item name="colorAccent">#3B82F6</item>
        <item name="android:windowBackground">#F0F4FF</item>
        <item name="android:statusBarColor">#1E3A8A</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>

    <!-- 主Tab文字样式 -->
    <style name="TabTextStyle" parent="android:TextAppearance">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#94A3B8</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- 子Tab文字样式 -->
    <style name="TabTextSub" parent="android:TextAppearance">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 按钮样式 - 主按钮 -->
    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#2563EB</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 按钮样式 - 次按钮 -->
    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#475569</item>
        <item name="strokeColor">#E2E8F0</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- 危险按钮 -->
    <style name="DangerButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#DC2626</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="AppCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>
</resources>
