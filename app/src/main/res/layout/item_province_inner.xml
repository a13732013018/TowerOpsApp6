<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧颜色条 -->
        <View
            android:id="@+id/viewHeatStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="60dp"
            android:background="@drawable/bg_card_heat_normal" />

        <!-- 内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 第一行：序号 + 处理人 + 分组 + 时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/tvPIIndex"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="1"
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_index_bubble" />

                <TextView
                    android:id="@+id/tvPIHandler"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="处理人"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_handler_tag"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="5dp" />

                <TextView
                    android:id="@+id/tvPIGroup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="分组"
                    android:textSize="10sp"
                    android:textColor="#8B5CF6"
                    android:layout_marginStart="5dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvPICreateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="9sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- 第二行：站名 + 工单数量 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvPIStationName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="站点名称"
                    android:textSize="14sp"
                    android:textColor="#1F2937"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvPIOrderCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3张"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_count_badge"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- 第三行：工单描述 + 类型 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="3dp">

                <TextView
                    android:id="@+id/tvPIOrderDesc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工单描述"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvPIOrderType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="综合"
                    android:textSize="10sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_tag_success"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- 第四行：任务名称 -->
            <TextView
                android:id="@+id/tvPIDataName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="任务名称"
                android:textSize="11sp"
                android:textColor="#059669"
                android:layout_marginBottom="2dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 第五行：流程名称 -->
            <TextView
                android:id="@+id/tvPIFlowName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="流程"
                android:textSize="10sp"
                android:textColor="#4B5563"
                android:layout_marginBottom="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- 第六行：要求完成时间 -->
            <TextView
                android:id="@+id/tvPIReqTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="要求完成: --"
                android:textSize="10sp"
                android:textColor="#EF4444" />
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
