<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 排序工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_secondary"
        android:padding="12dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序："
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnSortVoltage"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="电压 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/btnSortLoadCurrent"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="负载电流 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/btnSortAlarmTime"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="告警时间 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 表头 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:background="@color/background_tertiary"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="站点名称"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>

        <TextView
            android:layout_width="38dp"
            android:layout_height="wrap_content"
            android:text="电压(V)"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"/>

        <TextView
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="负载(A)"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"/>

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="类型"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="4dp"/>

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="告警时间"
            android:textColor="@color/text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 停电列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPowerOutages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"/>

</LinearLayout>
