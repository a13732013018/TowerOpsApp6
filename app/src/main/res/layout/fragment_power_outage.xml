<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 面板标题条（蓝色渐变顶部，与其他Tab统一） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel_header"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:elevation="1dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_outage_stripe"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="停电监控"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1E40AF"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="实时告警监测"
            android:textSize="10sp"
            android:textColor="#60A5FA"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 排序工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:background="@color/background_secondary"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:elevation="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="@color/divider"
            android:layout_marginEnd="8dp"/>

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnSortVoltage"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="电压 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortLoadCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="负载电流 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortAlarmTime"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="告警时间 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 表头 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:background="#EEF2FF"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_tertiary"
            android:textSize="9sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="站点名称"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="电压(V)"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="38dp"
            android:layout_height="wrap_content"
            android:text="负载(A)"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="类型"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="5dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="94dp"
            android:layout_height="wrap_content"
            android:text="告警时间"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:gravity="end"
            android:layout_marginStart="5dp"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 停电列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPowerOutages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"/>

</LinearLayout>
