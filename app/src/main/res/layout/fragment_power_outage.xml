<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- ══════════ 顶部面板标题条（红色告警风格） ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel_header"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:elevation="2dp">

        <View
            android:layout_width="3dp"
            android:layout_height="16dp"
            android:background="#EF4444"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔴 停电监控"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#B91C1C"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="实时告警监测"
            android:textSize="10sp"
            android:textColor="#F87171"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 排序工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:background="@color/background_secondary"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:elevation="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排序"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="@color/divider"
            android:layout_marginEnd="8dp"/>

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnSortVoltage"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="电压 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortLoadCurrent"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="负载电流 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/btnSortAlarmTime"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="告警时间 ↕"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_tag_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- 表头 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:background="#FFF1F2"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="#F87171"
            android:textSize="9sp"
            android:gravity="center"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="站点名称"
            android:textColor="#B91C1C"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="7dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="电压(V)"
            android:textColor="#B91C1C"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:text="负载(A)"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="4dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="类型"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="5dp"
            android:includeFontPadding="false"/>

        <TextView
            android:layout_width="96dp"
            android:layout_height="wrap_content"
            android:text="告警时间"
            android:textColor="@color/text_caption"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginStart="5dp"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FECACA"/>

    <!-- 停电列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPowerOutages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:paddingTop="2dp"
        android:paddingBottom="8dp"/>

</LinearLayout>
