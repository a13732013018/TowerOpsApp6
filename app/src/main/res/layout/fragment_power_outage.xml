<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 排序工具栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/background_secondary"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序："
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/btnSortVoltage"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="电压 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/btnSortLoadCurrent"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="负载电流 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/btnSortAlarmTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="告警时间 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 表头 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="@color/background_tertiary"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="站点名称"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="6dp"/>

        <TextView
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:text="电压"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="end"
            android:layout_marginStart="6dp"/>

        <TextView
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="负载"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="end"
            android:layout_marginStart="6dp"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="类型"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginStart="6dp"/>

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:text="告警时间"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

    <!-- 停电列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPowerOutages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
