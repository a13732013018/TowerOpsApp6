<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧热度颜色条 -->
        <View
            android:id="@+id/viewHeatStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="60dp"
            android:background="@drawable/bg_card_heat_normal" />

        <!-- 内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <!-- 第一行：序号 + 站名 + 状态标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvIndex"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_circle_blue"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvSiteName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="站点名称"
                    android:textSize="13sp"
                    android:textColor="#1F2937"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:text="未领取"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"
                    android:background="@drawable/bg_tag_zhilian"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginBottom="6dp" />

            <!-- 第二行：任务类型 + 创建时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="任务类型"
                        android:textSize="9sp"
                        android:textColor="#9CA3AF"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/tvTaskType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        android:layout_marginTop="1dp"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="创建时间"
                        android:textSize="9sp"
                        android:textColor="#9CA3AF"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/tvCreateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="12sp"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        android:layout_marginTop="1dp"
                        android:includeFontPadding="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- 处理人（已领取才显示） -->
            <LinearLayout
                android:id="@+id/layoutDealInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="处理人:"
                    android:textSize="9sp"
                    android:textColor="#9CA3AF"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tvDoDealName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="12sp"
                    android:textColor="#7C3AED"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- 操作按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btnManualAccept"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:text="手动接单"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn_zhilian_start"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:includeFontPadding="false" />

                <Button
                    android:id="@+id/btnManualRevert"
                    android:layout_width="72dp"
                    android:layout_height="30dp"
                    android:text="手动回单"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_progress_warning"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
