<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 排序工具栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/background_secondary"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序："
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/btnSortBillTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="工单历时 ↓"
                android:textSize="12sp"
                android:textColor="@color/text_inverse"
                android:background="@drawable/bg_tag_primary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/btnSortFeedbackTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="反馈历时 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/btnSortAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="告警时间 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/btnSortAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="告警状态 ↕"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_tag_secondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="8dp"/>

            <TextView
                android:id="@+id/tvSortDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工单历时 大→小"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:layout_marginStart="12dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 工单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWorkOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
