<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- 排序工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_secondary"
        android:padding="12dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序："
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnSortBillTime"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="工单历时 ↓"
                        android:textSize="13sp"
                        android:textColor="@color/text_inverse"
                        android:background="@drawable/bg_tag_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/btnSortFeedbackTime"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="反馈历时 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/btnSortAlertTime"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="告警时间 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:id="@+id/btnSortAlertStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="告警状态 ↕"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:background="@drawable/bg_tag_secondary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:gravity="center"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- 工单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWorkOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_primary"
        android:clipToPadding="false"
        android:padding="8dp"/>

</LinearLayout>
