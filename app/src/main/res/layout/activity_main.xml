<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ══════════════════════════════════════════════════
         顶部双层沉浸式导航栏（深蓝渐变，整体统一）
    ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerFrame"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── 第一层：品牌标题行 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical">

            <!-- Logo 图标容器（圆角方形） -->
            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_logo_container"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_logo_tower"
                    android:tint="#FFFFFF"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <!-- 标题文字组 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="铁塔运维助手"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOWER OPS SYSTEM"
                    android:textColor="#7BA7E8"
                    android:textSize="8sp"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="1dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 用户名（无边框，简洁文字） -->
            <TextView
                android:id="@+id/tvUserInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未登录"
                android:textColor="#BFDBFE"
                android:textSize="11sp"
                android:layout_marginEnd="12dp"
                android:includeFontPadding="false"/>

            <!-- 退出按钮 -->
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="52dp"
                android:layout_height="28dp"
                android:text="退出"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_outline"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- ── 第二层：状态信息条（深蓝底，内嵌信息胶囊） ── -->
        <LinearLayout
            android:id="@+id/statusBar"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="#1A3270"
            android:gravity="center_vertical">

            <!-- 运行状态指示灯 + 文字 -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_status_dot_idle"
                android:layout_marginEnd="5dp"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就绪"
                android:textColor="#86EFAC"
                android:textSize="10sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>

            <!-- 分隔竖线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="#FFFFFF"
                android:alpha="0.15"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"/>

            <!-- 本轮完成信息 -->
            <TextView
                android:id="@+id/tvRoundComplete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#93C5FD"
                android:textSize="10sp"
                android:includeFontPadding="false"
                android:ellipsize="end"
                android:singleLine="true"/>

            <!-- 倒计时：紧凑融合在右侧（仅文字，无面板） -->
            <TextView
                android:id="@+id/tvNextRun"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:text=""
                android:textColor="#60A5FA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_countdown_inline"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center_vertical"
                android:layout_marginStart="6dp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"/>

            <!-- 分隔竖线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:background="#FFFFFF"
                android:alpha="0.15"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <!-- 停电胶囊 -->
            <TextView
                android:id="@+id/tvPowerOutageCountStatus"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:text="⚡ 0"
                android:textColor="#FCA5A5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_outage_inline"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center_vertical"
                android:includeFontPadding="false"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════
         Tab切换（胶囊选中样式）
    ══════════════════════════════════════════════════ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#1D4ED8"
        app:tabTextColor="#9CA3AF"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="#152563EB"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="6dp"
        app:tabPaddingEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/headerFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tab底部细线 -->
    <View
        android:id="@+id/divider2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E8EFFF"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ══════════════════════════════════════════════════
         ViewPager2 内容区
    ══════════════════════════════════════════════════ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
