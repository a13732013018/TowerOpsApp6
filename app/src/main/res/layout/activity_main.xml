<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <!-- ==================== 顶部标题栏（深蓝品牌色） ==================== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/colorPrimaryDark"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 左侧竖线装饰 + 标题 -->
        <View
            android:layout_width="3dp"
            android:layout_height="20dp"
            android:background="#60A5FA"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="铁塔运维助手"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:includeFontPadding="false"/>

        <!-- 用户信息 -->
        <TextView
            android:id="@+id/tvUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未登录"
            android:textColor="#BFDBFE"
            android:textSize="12sp"
            android:layout_marginEnd="12dp"
            android:includeFontPadding="false"/>

        <!-- 退出按钮（细线框） -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="52dp"
            android:layout_height="28dp"
            android:text="退出"
            android:textColor="#BFDBFE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_outline"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- ==================== 状态信息栏（精简、单行） ==================== -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#EFF6FF"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 状态点 + 文字 -->
        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="就绪"
            android:textColor="@color/success"
            android:textSize="11sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_status_dot"
            android:drawablePadding="4dp"
            android:includeFontPadding="false"/>

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:background="#CBD5E1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvRoundComplete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:includeFontPadding="false"/>

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:background="#CBD5E1"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvPowerOutageCountStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停电: 0"
            android:textColor="@color/error"
            android:textSize="11sp"
            android:textStyle="bold"
            android:includeFontPadding="false"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvNextRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/info"
            android:textSize="11sp"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 底部蓝色细线分隔状态栏与Tab -->
    <View
        android:id="@+id/divider1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== Tab切换（白底，蓝色指示器） ==================== -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:background="@color/tab_background"
        android:elevation="2dp"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabTextColor="@color/tab_unselected"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="@color/colorPrimaryLight"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="4dp"
        app:tabPaddingEnd="4dp"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== ViewPager2 ==================== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
