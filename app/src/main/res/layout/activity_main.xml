<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- ==================== 顶部标题栏 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/header_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="铁塔运维助手"
            android:textColor="@color/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未登录"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="退出"
            android:textColor="@color/colorPrimary"
            android:textSize="12sp"
            android:background="@drawable/bg_tag_white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ==================== 配置控制区 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/control_panel_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="1dp">

        <!-- 第1行：三个CheckBox + 轮询区间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <CheckBox
                android:id="@+id/cbAutoFeedback"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="自动反馈"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:buttonTint="@color/colorPrimary"
                android:paddingStart="4dp"
                android:checked="true"
                android:minHeight="0dp"/>

            <CheckBox
                android:id="@+id/cbAutoAccept"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="自动接单"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:buttonTint="@color/colorPrimary"
                android:paddingStart="4dp"
                android:checked="true"
                android:minHeight="0dp"/>

            <CheckBox
                android:id="@+id/cbAutoRevert"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="自动回单"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:buttonTint="@color/colorPrimary"
                android:paddingStart="4dp"
                android:checked="true"
                android:minHeight="0dp"/>

            <!-- 轮询 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="轮询:"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
            <EditText
                android:id="@+id/etIntervalMin"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>
            <EditText
                android:id="@+id/etIntervalMax"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="120"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="秒"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:layout_marginStart="2dp"/>
        </LinearLayout>

        <!-- 第2行：反馈阈值 + 接单阈值 + 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical|start">

            <!-- 反馈阈值 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="反馈:"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>
            <EditText
                android:id="@+id/etFeedbackMin"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="70"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="~"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"/>
            <EditText
                android:id="@+id/etFeedbackMax"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>

            <!-- 接单阈值 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="接单:"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"/>
            <EditText
                android:id="@+id/etAcceptMin"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="60"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="~"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"/>
            <EditText
                android:id="@+id/etAcceptMax"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_input_white"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="90"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="4dp"/>

            <!-- 按钮组 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="开启监控"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/button_primary_text"
                android:background="@drawable/bg_button_primary_white"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <Button
                android:id="@+id/btnStopMonitor"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="停止"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/button_secondary_text"
                android:background="@drawable/bg_button_secondary_white"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ==================== 状态栏 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/status_bar_background"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启动"
            android:textColor="@color/success"
            android:textSize="12sp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="@color/divider"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvRoundComplete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="@color/divider"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvPowerOutageCountStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停电 0"
            android:textColor="@color/error"
            android:textSize="12sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvNextRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/success"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ==================== Tab切换 + ViewPager2 ==================== -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/tab_background"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabTextColor="@color/text_secondary"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="@color/colorPrimaryLight"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="0dp"
        app:tabPaddingEnd="0dp"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
