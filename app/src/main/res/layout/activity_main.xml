<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ==================== 顶部标题栏（横向渐变深蓝） ==================== -->
    <FrameLayout
        android:id="@+id/headerFrame"
        android:layout_width="0dp"
        android:layout_height="62dp"
        android:background="@drawable/bg_header_gradient"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 右侧光晕装饰 -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_glow_blue"
            android:layout_gravity="end|center_vertical"
            android:translationX="60dp"
            android:alpha="0.35"/>

        <!-- 实际内容行 -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical">

            <!-- 左侧品牌竖线（白色，加粗） -->
            <View
                android:layout_width="3dp"
                android:layout_height="26dp"
                android:background="#FFFFFF"
                android:alpha="0.7"
                android:layout_marginEnd="12dp"/>

            <!-- Logo小图标 -->
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_logo_tower"
                android:tint="#FFFFFF"
                android:layout_marginEnd="10dp"/>

            <!-- 标题 + 副标题 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="铁塔运维助手"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tower Operations"
                    android:textColor="#93C5FD"
                    android:textSize="9sp"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 用户信息徽章 -->
            <TextView
                android:id="@+id/tvUserInfo"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="未登录"
                android:textColor="#DBEAFE"
                android:textSize="11sp"
                android:background="@drawable/bg_user_badge"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:layout_marginEnd="8dp"
                android:includeFontPadding="false"/>

            <!-- 退出按钮（细线框） -->
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="54dp"
                android:layout_height="32dp"
                android:text="退出"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_outline"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </FrameLayout>

    <!-- ==================== 状态信息栏（浅蓝渐变背景） ==================== -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_status_bar_gradient"
        android:gravity="center_vertical"
        android:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/headerFrame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 状态胶囊（就绪/运行中） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_success"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/bg_circle_deco_large"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就绪"
                android:textColor="#059669"
                android:textSize="10sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="#D1D5DB"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvRoundComplete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#4B5563"
            android:textSize="10sp"
            android:includeFontPadding="false"/>

        <!-- 停电数量胶囊 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_error"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvPowerOutageCountStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ 停电: 0"
                android:textColor="#DC2626"
                android:textSize="10sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ==================== 🔥 数字倒计时面板（深蓝科技感） ==================== -->
    <LinearLayout
        android:id="@+id/countdownPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_countdown_panel"
        android:gravity="center_horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:elevation="2dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 标签行 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT EXECUTION IN"
            android:textColor="#3a5fa0"
            android:textSize="8sp"
            android:letterSpacing="0.20"
            android:includeFontPadding="false"
            android:layout_marginBottom="6dp"/>

        <!-- 数字时钟行 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <!-- 分钟组 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDigitMin1"
                        android:layout_width="32dp"
                        android:layout_height="44dp"
                        android:text="0"
                        android:textColor="#60a5fa"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_digit_box"
                        android:fontFamily="monospace"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="2dp"/>

                    <TextView
                        android:id="@+id/tvDigitMin2"
                        android:layout_width="32dp"
                        android:layout_height="44dp"
                        android:text="0"
                        android:textColor="#60a5fa"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_digit_box"
                        android:fontFamily="monospace"
                        android:includeFontPadding="false"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分"
                    android:textColor="#2d5090"
                    android:textSize="8sp"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 冒号分隔 -->
            <TextView
                android:id="@+id/tvClockColon"
                android:layout_width="16dp"
                android:layout_height="44dp"
                android:text=":"
                android:textColor="#1e4080"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"/>

            <!-- 秒组 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDigitSec1"
                        android:layout_width="32dp"
                        android:layout_height="44dp"
                        android:text="0"
                        android:textColor="#60a5fa"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_digit_box"
                        android:fontFamily="monospace"
                        android:includeFontPadding="false"
                        android:layout_marginEnd="2dp"/>

                    <TextView
                        android:id="@+id/tvDigitSec2"
                        android:layout_width="32dp"
                        android:layout_height="44dp"
                        android:text="0"
                        android:textColor="#60a5fa"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_digit_box"
                        android:fontFamily="monospace"
                        android:includeFontPadding="false"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="秒"
                    android:textColor="#2d5090"
                    android:textSize="8sp"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 进度条 -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="3dp"
            android:background="@drawable/bg_clock_progress"
            android:layout_marginBottom="5dp">

            <View
                android:id="@+id/clockProgressFill"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="@drawable/bg_clock_progress_fill"/>
        </FrameLayout>

        <!-- 下次执行时间文字 -->
        <TextView
            android:id="@+id/tvNextRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#3a5fa0"
            android:textSize="9sp"
            android:letterSpacing="0.05"
            android:includeFontPadding="false"/>

    </LinearLayout>

    <!-- 状态栏底部阴影线 -->
    <View
        android:id="@+id/divider1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#DCE8FF"
        app:layout_constraintTop_toBottomOf="@id/countdownPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== Tab切换（渐变白底，蓝色指示器加粗） ==================== -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_tab_bar"
        android:elevation="4dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#1D4ED8"
        app:tabTextColor="#94A3B8"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="#152563EB"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="8dp"
        app:tabPaddingEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tab底部阴影线 -->
    <View
        android:id="@+id/divider2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0EAFF"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== ViewPager2 ==================== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
