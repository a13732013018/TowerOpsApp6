<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <!-- ==================== 顶部标题栏（渐变深蓝） ==================== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 左侧品牌竖线（渐变蓝白） -->
        <View
            android:layout_width="3dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_card_stripe_info"
            android:layout_marginEnd="12dp"/>

        <!-- Logo小图标 -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_logo_tower"
            android:tint="#FFFFFF"
            android:alpha="0.9"
            android:layout_marginEnd="9dp"/>

        <!-- 标题 + 副标题 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="铁塔运维助手"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:includeFontPadding="false"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tower Operations"
                android:textColor="#7DD3FC"
                android:textSize="9sp"
                android:letterSpacing="0.05"
                android:layout_marginTop="1dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 用户信息徽章 -->
        <TextView
            android:id="@+id/tvUserInfo"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="未登录"
            android:textColor="#BFDBFE"
            android:textSize="11sp"
            android:background="@drawable/bg_user_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:includeFontPadding="false"/>

        <!-- 退出按钮（细线框） -->
        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="52dp"
            android:layout_height="30dp"
            android:text="退出"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- ==================== 状态信息栏（精简胶囊） ==================== -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 状态胶囊（就绪/运行中） -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_success"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_circle_deco_large"
                android:tint="#059669"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="就绪"
                android:textColor="#059669"
                android:textSize="11sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="#E2E8F0"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/tvRoundComplete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#64748B"
            android:textSize="11sp"
            android:includeFontPadding="false"/>

        <!-- 停电数量胶囊 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_badge_error"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:id="@+id/tvPowerOutageCountStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ 停电: 0"
                android:textColor="#DC2626"
                android:textSize="11sp"
                android:textStyle="bold"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvNextRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#2563EB"
            android:textSize="11sp"
            android:includeFontPadding="false"/>
    </LinearLayout>

    <!-- 状态栏底部细线 -->
    <View
        android:id="@+id/divider1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== Tab切换（白底，蓝色指示器） ==================== -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:background="#FFFFFF"
        android:elevation="3dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#1D4ED8"
        app:tabTextColor="#94A3B8"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="#1A2563EB"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="6dp"
        app:tabPaddingEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tab底部细线 -->
    <View
        android:id="@+id/divider2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ==================== ViewPager2 ==================== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
