<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- ====== 控制栏 ====== -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="2dp"
        app:cardCornerRadius="7dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/background_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="5dp"
            android:paddingBottom="3dp">

            <!-- 第一行：区县选择 + 查询按钮 + 排序按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="区县"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold"/>

                <Spinner
                    android:id="@+id/spinnerKHCounty"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_input_white"/>

                <Button
                    android:id="@+id/btnKHQuery"
                    android:layout_width="56dp"
                    android:layout_height="30dp"
                    android:text="查询"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"/>

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="2dp"
                android:background="#DDEAFF"/>

            <!-- 过滤+排序 同一行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 过滤标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="过滤:"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp"/>

                <!-- cb10 -->
                <CheckBox
                    android:id="@+id/cbKHFilter10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动审核"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <!-- cb17 -->
                <CheckBox
                    android:id="@+id/cbKHFilter17"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="杂单"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="false"/>

                <!-- 排序标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="排序:"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="2dp"/>

                <!-- 排序字段选择 -->
                <Spinner
                    android:id="@+id/spinnerKHSortField"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1.2"
                    android:background="@drawable/bg_input_white"/>

                <!-- 正反序切换按钮 -->
                <Button
                    android:id="@+id/btnKHSortDir"
                    android:layout_width="28dp"
                    android:layout_height="26dp"
                    android:text="↑"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_inverse"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:stateListAnimator="@null"
                    android:letterSpacing="0"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:layout_marginStart="2dp"/>

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:background="#DDEAFF"/>

            <!-- 特殊工单类型：全部挤在2行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="类型:"
                    android:textSize="9sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp"
                    android:gravity="center_vertical"/>

                <CheckBox
                    android:id="@+id/cbKHFilter13"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="验收遗留"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <CheckBox
                    android:id="@+id/cbKHFilter14"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="退服稽核"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <CheckBox
                    android:id="@+id/cbKHFilter15"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="信号整治"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <CheckBox
                    android:id="@+id/cbKHFilter16"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="储能验收"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <CheckBox
                    android:id="@+id/cbKHFilter22"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="智联/高铁"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="true"/>

                <CheckBox
                    android:id="@+id/cbKHFilter18"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="全不选"
                    android:textSize="9sp"
                    android:minHeight="0dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:checked="false"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ====== 状态栏 ====== -->
    <TextView
        android:id="@+id/tvKHStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="选择区县后点击查询"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"/>

    <!-- ====== 列表 ====== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvKaoHeOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
