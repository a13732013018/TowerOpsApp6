<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvShuyunStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="数运监控未启动"
            android:textSize="14sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:fontFamily="monospace"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理: 0"
            android:textSize="13sp"
            android:textColor="#2563EB"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvProcessingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中: 0"
            android:textSize="13sp"
            android:textColor="#10B981" />
    </LinearLayout>

    <!-- 控制面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@android:color/white"
        android:layout_marginTop="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbAutoAccept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动接单"
            android:textSize="13sp"
            android:checked="true" />

            <ImageView
                android:id="@+id/ivAutoAcceptInfo"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:tint="#9CA3AF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

        <CheckBox
            android:id="@+id/cbAutoRevert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动回单"
            android:textSize="13sp"
            android:checked="true" />

            <ImageView
                android:id="@+id/ivAutoRevertInfo"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:tint="#9CA3AF" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnStartShuyun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="启动监控"
            android:textSize="12sp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnStopShuyun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="停止"
            android:textSize="12sp"
            android:backgroundTint="#EF4444"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Tab 切换 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutShuyun"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@android:color/white"
        android:layout_marginTop="8dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#2563EB"
        app:tabTextColor="#666666"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中" />

    </com.google.android.material.tabs.TabLayout>

    <!-- 列表区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="1dp">

        <!-- 待处理列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPending"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <!-- 处理中列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProcessing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- 空状态 -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="16sp"
            android:textColor="#999999"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 日志区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:background="#1F2937"
        android:layout_marginTop="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="运行日志"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#111827" />

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E5E7EB"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.2" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
