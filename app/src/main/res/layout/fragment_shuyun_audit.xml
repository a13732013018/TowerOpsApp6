<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvAuditTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="数运审核"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCountyStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未启动"
            android:textSize="13sp"
            android:textColor="#6B7280" />
    </LinearLayout>

    <!-- 审核控制面板（紧凑布局） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@android:color/white"
        android:layout_marginTop="6dp">

        <!-- 区县选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择区县:"
                android:textSize="13sp"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinnerCounty"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />
        </LinearLayout>

        <!-- 县级审核按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnCountyAudit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="开始县级审核"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#F59E0B" />

            <Button
                android:id="@+id/btnStopCountyAudit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="停止"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:enabled="false" />
        </LinearLayout>

        <!-- 市级审核按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCityAudit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="开始市级审核"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#8B5CF6" />

            <Button
                android:id="@+id/btnStopCityAudit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="停止"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EF4444"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- 功能说明（紧凑布局） -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#EFF6FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能说明"
                android:textSize="12sp"
                android:textColor="#1E40AF"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• 县级审核：区县经理审批（橙色按钮）"
                android:textSize="11sp"
                android:textColor="#3B82F6"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• 市级审核：市公司审批（紫色按钮）"
                android:textSize="11sp"
                android:textColor="#3B82F6"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• 省级审核：省公司审批（开发中...）"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• 仿生延迟防封，自动通过审核"
                android:textSize="11sp"
                android:textColor="#3B82F6" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 市级已办列表（显示前3条） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ECFDF5"
        android:layout_marginTop="6dp"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="市级已办（最近3条）"
            android:textSize="11sp"
            android:textColor="#059669"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCityFinishedList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无已办记录"
            android:textSize="10sp"
            android:textColor="#047857"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2" />
    </LinearLayout>

    <!-- 日志区域（加大高度） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1F2937"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="审核日志"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="#111827" />

        <ScrollView
            android:id="@+id/svAuditLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvAuditLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#E5E7EB"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.1" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
