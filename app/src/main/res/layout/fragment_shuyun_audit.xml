<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 控制面板 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数运审核"
                android:textSize="12sp"
                android:textColor="#1D4ED8"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 区县选择 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="选择区县"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerCounty"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_spinner"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="10dp" />

            <!-- 审核按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnCountyAudit"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="县级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_county_audit"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnCityAudit"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="市级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_city_audit"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnProvinceAudit"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="省级审核"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_province_audit"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 停止按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStopCountyAudit"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:background="@drawable/bg_button_gray"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnStopCityAudit"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:background="@drawable/bg_button_gray"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnStopProvinceAudit"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:background="@drawable/bg_button_gray"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:enabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 市级已办 / 省监控回单 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 市级已办 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="市级已办"
                    android:textSize="11sp"
                    android:textColor="#7C3AED"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCityTodoList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无待办"
                android:textSize="10sp"
                android:textColor="#6B7280"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp" />

            <!-- 省监控回单 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="省监控回单"
                    android:textSize="11sp"
                    android:textColor="#059669"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnProvinceMonitorAudit"
                    android:layout_width="60dp"
                    android:layout_height="28dp"
                    android:text="回单"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_success"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCityFinishedList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无省监控工单"
                android:textSize="10sp"
                android:textColor="#6B7280"
                android:fontFamily="monospace" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 日志区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1E293B">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="#0F172A">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="审核日志"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textSize="9sp"
                android:textColor="#22C55E" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/svAuditLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvAuditLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#94A3B8"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
