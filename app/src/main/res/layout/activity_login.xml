<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Logo 区域 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="40dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="20dp"
                android:src="@drawable/ic_logo_tower"
                android:background="@drawable/bg_button_primary_gradient"
                android:padding="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="铁塔运维助手"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.02"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOWER OPERATIONS"
                android:textSize="13sp"
                android:textStyle="normal"
                android:textColor="#606080"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- 登录卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_glass"
            android:padding="32dp">

            <!-- 账号选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择账号"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#8080A0"
                android:letterSpacing="0.03"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spinnerAccount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_glass"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp" />

            <!-- 图形验证码 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="图形验证码"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#8080A0"
                android:letterSpacing="0.03"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <FrameLayout
                    android:id="@+id/flCaptcha"
                    android:layout_width="180dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_captcha_glass"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivCaptcha"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitCenter"
                        android:padding="8dp" />

                </FrameLayout>

                <Button
                    android:id="@+id/btnRefreshCaptcha"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="刷新"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <EditText
                android:id="@+id/etVerifyCode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_glass"
                android:hint="请输入验证码"
                android:textColorHint="#606080"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- PIN码 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="短信验证码 / PIN码"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#8080A0"
                android:letterSpacing="0.03"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etPin"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_glass"
                    android:hint="请输入PIN码"
                    android:textColorHint="#606080"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="text" />

                <Button
                    android:id="@+id/btnGetSms"
                    android:layout_width="130dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="获取验证码"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <!-- 登录按钮 -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary_gradient"
                android:text="登 录"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.06" />

            <!-- 状态提示 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text=""
                android:textSize="13sp"
                android:textStyle="normal"
                android:textColor="#E94560"
                android:minHeight="20dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
