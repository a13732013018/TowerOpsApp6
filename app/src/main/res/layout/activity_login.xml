<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- ===== 背景光晕层（大尺寸，多颜色，营造深邃空间感） ===== -->

    <!-- 右上角主蓝色大光晕 -->
    <View
        android:layout_width="360dp"
        android:layout_height="360dp"
        android:background="@drawable/bg_glow_blue"
        android:layout_gravity="top|end"
        android:translationX="120dp"
        android:translationY="-100dp"/>

    <!-- 左下角紫色大光晕 -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_purple"
        android:layout_gravity="bottom|start"
        android:translationX="-80dp"
        android:translationY="80dp"/>

    <!-- 左上角青色小光晕（点睛） -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_cyan"
        android:layout_gravity="top|start"
        android:translationX="-40dp"
        android:translationY="160dp"/>

    <!-- 中央微弱蓝色光晕（让卡片区域有发光感） -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glow_blue"
        android:layout_gravity="center"
        android:alpha="0.18"/>

    <!-- ===== 主体可滚动内容 ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="68dp"
            android:paddingBottom="44dp">

            <!-- ===== LOGO区域 ===== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="36dp">

                <!-- Logo 外圈光晕 -->
                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center">

                    <!-- 光晕背景圆 -->
                    <View
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:background="@drawable/bg_glow_blue"
                        android:alpha="0.6"/>

                    <!-- Logo 主体 Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="24dp"
                        app:cardBackgroundColor="#1D4ED8">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_button_primary_gradient">

                            <!-- 内部右上角高光 -->
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_gravity="top|end"
                                android:translationX="16dp"
                                android:translationY="-16dp"
                                android:background="@drawable/bg_circle_deco_large"
                                android:alpha="0.2"/>

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_logo_tower"
                                android:tint="#FFFFFF"/>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>
                </FrameLayout>

                <!-- 主标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="铁塔运维助手"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.06"
                    android:layout_marginTop="22dp"
                    android:includeFontPadding="false"/>

                <!-- 副标题（有字母间距，科技感） -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="T O W E R  O P S  S Y S T E M"
                    android:textSize="10sp"
                    android:textColor="#60A5FA"
                    android:letterSpacing="0.18"
                    android:layout_marginTop="8dp"
                    android:includeFontPadding="false"/>

                <!-- 版本徽章 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="  v6.0 Professional  "
                    android:textSize="10sp"
                    android:textColor="#93C5FD"
                    android:background="@drawable/bg_version_badge"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- ===== 登录卡片（霜玻璃白卡，更大圆角更大阴影） ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="32dp"
                app:cardBackgroundColor="#F8FAFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="26dp"
                    android:paddingEnd="26dp"
                    android:paddingTop="30dp"
                    android:paddingBottom="28dp">

                    <!-- 卡片内顶部标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="26dp">

                        <!-- 蓝色竖线 accent -->
                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="账号登录"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#0F172A"
                            android:includeFontPadding="false"/>

                        <!-- 安全标签 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="24dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_badge_success"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="5dp"
                                android:background="@drawable/bg_circle_deco_large"
                                android:layout_marginEnd="4dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="安全"
                                android:textSize="10sp"
                                android:textColor="#059669"
                                android:textStyle="bold"
                                android:includeFontPadding="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- ── 选择账号 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择账号"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <Spinner
                        android:id="@+id/spinnerAccount"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_blue"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- ── 图形验证码 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="图形验证码"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <FrameLayout
                            android:id="@+id/flCaptcha"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="2"
                            android:background="@drawable/bg_input_blue"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/ivCaptcha"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:padding="8dp"/>
                        </FrameLayout>

                        <Button
                            android:id="@+id/btnRefreshCaptcha"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:text="刷新"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:stateListAnimator="@null"
                            android:includeFontPadding="false"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etVerifyCode"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_blue"
                        android:hint="请输入图形验证码"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:layout_marginBottom="20dp"/>

                    <!-- ── PIN码 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="短信验证码 / PIN码"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="28dp">

                        <EditText
                            android:id="@+id/etPin"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_blue"
                            android:hint="请输入PIN码"
                            android:textColorHint="#94A3B8"
                            android:textColor="#0F172A"
                            android:textSize="15sp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:inputType="text"/>

                        <Button
                            android:id="@+id/btnGetSms"
                            android:layout_width="110dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:text="获取验证码"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:stateListAnimator="@null"
                            android:includeFontPadding="false"/>
                    </LinearLayout>

                    <!-- ── 登录按钮（终极大气版） ── -->
                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:background="@drawable/bg_btn_login"
                        android:text="立即登录"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.12"
                        android:stateListAnimator="@null"
                        android:elevation="6dp"
                        android:includeFontPadding="false"/>

                    <!-- 状态提示 -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/error"
                        android:minHeight="18dp"
                        android:gravity="center"
                        android:includeFontPadding="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 底部版权信息 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tower Operations System © 2026"
                android:textSize="10sp"
                android:textColor="#3B6FC4"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.04"
                android:includeFontPadding="false"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
