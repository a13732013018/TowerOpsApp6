<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- ===== 装饰圆圈（右上角大圆 + 左下小圆，纯色半透明） ===== -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_circle_deco_large"
        android:layout_gravity="top|end"
        android:translationX="80dp"
        android:translationY="-80dp"
        android:alpha="0.12"/>

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_circle_deco_large"
        android:layout_gravity="bottom|start"
        android:translationX="-50dp"
        android:translationY="50dp"
        android:alpha="0.08"/>

    <!-- 中间小装饰圆点 -->
    <View
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_circle_deco_large"
        android:layout_gravity="top|start"
        android:translationX="30dp"
        android:translationY="200dp"
        android:alpha="0.06"/>

    <!-- ===== 主体可滚动内容 ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="72dp"
            android:paddingBottom="48dp">

            <!-- ===== LOGO区域 ===== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="44dp">

                <!-- Logo 图标圆框 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="20dp"
                    app:cardBackgroundColor="#1D4ED8">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_primary_gradient">

                        <!-- 内部光晕效果 -->
                        <View
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="top|start"
                            android:translationX="-15dp"
                            android:translationY="-15dp"
                            android:background="@drawable/bg_circle_deco_large"
                            android:alpha="0.15"/>

                        <ImageView
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_logo_tower"
                            android:tint="#FFFFFF"/>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- 主标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="铁塔运维助手"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.04"
                    android:layout_marginTop="24dp"
                    android:includeFontPadding="false"/>

                <!-- 副标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tower Operations System"
                    android:textSize="12sp"
                    android:textColor="#7CB9F0"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="7dp"
                    android:includeFontPadding="false"/>

                <!-- 版本徽章 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:text="  v6.0 Professional  "
                    android:textSize="10sp"
                    android:textColor="#93C5FD"
                    android:background="@drawable/bg_version_badge"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- ===== 登录卡片 ===== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="24dp"
                app:cardBackgroundColor="#FAFBFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="28dp">

                    <!-- 卡片内顶部标题行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="28dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="22dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="账号登录"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#0F172A"
                            android:includeFontPadding="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="22dp"
                            android:text="安全登录"
                            android:textSize="10sp"
                            android:textColor="#2563EB"
                            android:background="@drawable/bg_tag_inactive"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:gravity="center"
                            android:includeFontPadding="false"/>
                    </LinearLayout>

                    <!-- ── 选择账号 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择账号"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <Spinner
                        android:id="@+id/spinnerAccount"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_blue"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="22dp"/>

                    <!-- ── 图形验证码 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="图形验证码"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <FrameLayout
                            android:id="@+id/flCaptcha"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="2"
                            android:background="@drawable/bg_input_blue"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/ivCaptcha"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:padding="8dp"/>
                        </FrameLayout>

                        <Button
                            android:id="@+id/btnRefreshCaptcha"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:text="刷新"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:stateListAnimator="@null"
                            android:includeFontPadding="false"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etVerifyCode"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_blue"
                        android:hint="请输入图形验证码"
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:layout_marginBottom="22dp"/>

                    <!-- ── PIN码 ── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="短信验证码 / PIN码"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#475569"
                        android:layout_marginBottom="8dp"
                        android:includeFontPadding="false"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="28dp">

                        <EditText
                            android:id="@+id/etPin"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_blue"
                            android:hint="请输入PIN码"
                            android:textColorHint="#94A3B8"
                            android:textColor="#0F172A"
                            android:textSize="15sp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:inputType="text"/>

                        <Button
                            android:id="@+id/btnGetSms"
                            android:layout_width="110dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_button_primary_gradient"
                            android:text="获取验证码"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:stateListAnimator="@null"
                            android:includeFontPadding="false"/>
                    </LinearLayout>

                    <!-- ── 登录按钮 ── -->
                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_button_primary_gradient"
                        android:text="登  录"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.1"
                        android:stateListAnimator="@null"
                        android:includeFontPadding="false"/>

                    <!-- 状态提示 -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/error"
                        android:minHeight="18dp"
                        android:gravity="center"
                        android:includeFontPadding="false"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
