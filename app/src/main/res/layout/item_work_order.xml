<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/list_item_background"
    android:padding="14dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="6dp"
    android:elevation="1dp">

    <!-- 第一行：序号 + 工单号 + 告警状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvIndex"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvBillSn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="工单号"
            android:textColor="@color/colorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAlertStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="告警中"
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:background="@drawable/bg_tag_warning"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />
    </LinearLayout>

    <!-- 第二行：站点 + 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="站点名 - 工单标题"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- 第三行：接单人 + 创建时间 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvAcceptOp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="接单人：-"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCreateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="创建：-"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 第四行：最近处理信息 -->
    <TextView
        android:id="@+id/tvDealInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/success"
        android:textSize="13sp"
        android:layout_marginBottom="6dp"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- 第五行：工单历时 -->
    <TextView
        android:id="@+id/tvTimeDiff2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="工单历时：0分钟"
        android:textColor="@color/info"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- 第六行：上次反馈时间 -->
    <TextView
        android:id="@+id/tvTimeDiff"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="上次反馈：尚未反馈"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- 第七行：告警发生时间 -->
    <TextView
        android:id="@+id/tvAlertTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/warning"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- 第八行：当前状态 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--排队等待处理中..."
        android:textColor="@color/warning"
        android:textSize="13sp" />

</LinearLayout>
