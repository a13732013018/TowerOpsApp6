<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/background_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- 第一行：序号 + 工单号 + 告警状态标签 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- 序号气泡 -->
            <TextView
                android:id="@+id/tvIndex"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="1"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:gravity="center"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/tvBillSn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="工单号"
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/tvAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:text="告警中"
                android:textColor="@color/warning"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_tag_warning"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 第二行：站点 + 工单标题（主信息，突出显示） -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="站点名 - 工单标题"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2"
            android:includeFontPadding="false"/>

        <!-- 第三行：接单人 + 创建时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAcceptOp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="接单人：-"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="4dp"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/tvCreateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="创建：-"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light"
            android:layout_marginBottom="8dp"/>

        <!-- 第四行：最近处理信息 -->
        <TextView
            android:id="@+id/tvDealInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/success"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:drawableStart="@drawable/ic_check_circle"
            android:drawablePadding="5dp"
            android:includeFontPadding="false"/>

        <!-- 第五行：工单历时 -->
        <TextView
            android:id="@+id/tvTimeDiff2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="工单历时：0分钟"
            android:textColor="@color/info"
            android:textSize="12sp"
            android:layout_marginBottom="5dp"
            android:drawableStart="@drawable/ic_time"
            android:drawablePadding="5dp"
            android:includeFontPadding="false"/>

        <!-- 第六行：上次反馈时间 -->
        <TextView
            android:id="@+id/tvTimeDiff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上次反馈：尚未反馈"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="5dp"
            android:includeFontPadding="false"/>

        <!-- 第七行：告警发生时间 -->
        <TextView
            android:id="@+id/tvAlertTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:layout_marginBottom="5dp"
            android:drawableStart="@drawable/ic_warning"
            android:drawablePadding="5dp"
            android:includeFontPadding="false"/>

        <!-- 第八行：当前状态（底部最终状态） -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--排队等待处理中..."
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:includeFontPadding="false"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
