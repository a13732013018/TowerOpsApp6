<?xml version="1.0" encoding="utf-8"?>
<!--
    工单卡片 v6 APEX:
    - 顶部 4dp 三色横条（蓝→青→紫）+ 光泽感
    - 左侧 4dp 热度竖条（按优先级变色：红/橙/绿）
    - 卡片底部：历时徽章 + 热度进度条 + 状态文字
    - 整体白底圆角16dp + 蓝色阴影
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:orientation="vertical"
    android:background="@drawable/bg_card_v5"
    android:elevation="4dp">

    <!-- 顶部三色渐变横条 4dp -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/bg_card_top_stripe_v6"/>

    <!-- 横向主体：左竖线 + 内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧热度色竖条 4dp（默认橙色，代码动态切换） -->
        <View
            android:id="@+id/viewHeatStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_heat_warning"
            android:minHeight="64dp"/>

        <!-- 右侧内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- 第一行：序号气泡 + 工单号 + 告警状态标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/tvIndex"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_index_bubble"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvBillSn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工单号"
                    android:textColor="#1D4ED8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginStart="7dp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvAlertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="19dp"
                    android:text="告警中"
                    android:textColor="#F97316"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag_warning"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 第二行：站点名（主信息、大字加粗） -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="站点名 · 工单标题"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="7dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"
                android:includeFontPadding="false"/>

            <!-- 细分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#EEF2FF"
                android:layout_marginBottom="7dp"/>

            <!-- 第三行：接单人 + 创建时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvAcceptOp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="接单人：-"
                    android:textColor="#64748B"
                    android:textSize="10sp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvCreateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建：-"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 第四行：处理信息 -->
            <TextView
                android:id="@+id/tvDealInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#059669"
                android:textSize="10sp"
                android:layout_marginBottom="3dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_check_circle"
                android:drawablePadding="4dp"
                android:includeFontPadding="false"/>

            <!-- 第五行：上次反馈 + 告警时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvTimeDiff"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="上次反馈：尚未"
                    android:textColor="#94A3B8"
                    android:textSize="9sp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvAlertTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#F97316"
                    android:textSize="9sp"
                    android:drawableStart="@drawable/ic_warning"
                    android:drawablePadding="3dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 底部行：历时徽章 + 热度进度条 + 状态文字 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <!-- 工单历时徽章 -->
                <TextView
                    android:id="@+id/tvTimeDiff2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="历时 -"
                    android:textColor="#2563EB"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_duration_badge"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:layout_marginEnd="8dp"/>

                <!-- 热度进度条（外轨） -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_track">

                    <View
                        android:id="@+id/viewHeatProgress"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_gravity="start|center_vertical"
                        android:background="@drawable/bg_progress_warning"/>
                </FrameLayout>

                <!-- 状态文字 -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="等待处理"
                    android:textColor="#F97316"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:includeFontPadding="false"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
