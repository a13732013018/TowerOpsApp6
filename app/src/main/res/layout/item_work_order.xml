<?xml version="1.0" encoding="utf-8"?>
<!--
    工单卡片：左侧彩色状态条（告警橙/正常绿/处理蓝）+ 右侧信息区
    视觉层次：工单号蓝色 → 站点名大字加粗 → 接单人/时间灰色
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <!-- 整体横向：左侧色条 + 内容区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧状态色条（4dp宽，渐变色） -->
        <View
            android:id="@+id/viewStatusStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_stripe_warning"
            android:minHeight="60dp"/>

        <!-- 右侧内容区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp">

            <!-- 第一行：序号 + 工单号 + 告警状态标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="7dp">

                <!-- 序号圆形气泡 -->
                <TextView
                    android:id="@+id/tvIndex"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_index_bubble"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvBillSn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工单号"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvAlertStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:text="告警中"
                    android:textColor="#F97316"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag_warning"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:gravity="center"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 第二行：站点名（主信息、大字加粗） -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="站点名 · 工单标题"
                android:textColor="#0F172A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="9dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"
                android:includeFontPadding="false"/>

            <!-- 分割线（极细） -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#EEF2FF"
                android:layout_marginBottom="8dp"/>

            <!-- 第三行：接单人 + 创建时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvAcceptOp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="接单人：-"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvCreateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建：-"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 第四行：最近处理信息 -->
            <TextView
                android:id="@+id/tvDealInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#059669"
                android:textSize="11sp"
                android:layout_marginBottom="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_check_circle"
                android:drawablePadding="5dp"
                android:includeFontPadding="false"/>

            <!-- 第五行：工单历时 + 上次反馈时间 同行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvTimeDiff2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="工单历时：-"
                    android:textColor="#2563EB"
                    android:textSize="11sp"
                    android:drawableStart="@drawable/ic_time"
                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvTimeDiff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="上次反馈：尚未"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <!-- 第六行：告警时间 + 当前状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAlertTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#F97316"
                    android:textSize="11sp"
                    android:drawableStart="@drawable/ic_warning"
                    android:drawablePadding="4dp"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="等待处理"
                    android:textColor="#F97316"
                    android:textSize="10sp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
