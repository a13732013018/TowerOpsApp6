<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- 标题区域 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="铁塔4A系统登录"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4a.chinatowercom.cn"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="40dp" />

        <!-- 登录卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_login_card"
            android:padding="24dp">

            <!-- 账号 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账号"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTowerUsername"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_blue"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColor="@color/input_text"
                android:textColorHint="@color/text_tertiary"
                android:hint="请输入账号"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="16dp" />

            <!-- 密码 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="密码"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTowerPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_blue"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:textColor="@color/input_text"
                android:textColorHint="@color/text_tertiary"
                android:hint="请输入密码"
                android:inputType="textPassword"
                android:singleLine="true"
                android:layout_marginBottom="20dp" />

            <!-- 获取短信验证码按钮 -->
            <Button
                android:id="@+id/btnTowerGetSms"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_button_outline_primary"
                android:text="获取短信验证码"
                android:textSize="14sp"
                android:textColor="#60A5FA"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp" />

            <!-- 短信验证码 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="短信验证码"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTowerSmsCode"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input_blue"
                android:paddingHorizontal="12dp"
                android:textSize="18sp"
                android:textColor="@color/input_text"
                android:textColorHint="@color/text_tertiary"
                android:hint="请输入6位验证码"
                android:inputType="number"
                android:maxLength="6"
                android:singleLine="true"
                android:layout_marginBottom="20dp"
                android:letterSpacing="0.3" />

            <!-- 状态提示 -->
            <TextView
                android:id="@+id/tvTowerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:minHeight="20dp"
                android:layout_marginBottom="16dp" />

            <!-- 登录按钮 -->
            <Button
                android:id="@+id/btnTowerLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_login_gradient"
                android:text="登 录"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- 返回链接 -->
        <TextView
            android:id="@+id/tvTowerBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← 返回其他登录"
            android:textSize="13sp"
            android:textColor="#64748B"
            android:layout_marginTop="24dp"
            android:paddingVertical="8dp" />

    </LinearLayout>

</ScrollView>
