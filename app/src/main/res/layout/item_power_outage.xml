<?xml version="1.0" encoding="utf-8"?>
<!-- 紧凑型停电列表项：去掉分组，一行显示 -->
<!-- 列宽设置：序号20dp | 站点名称自适应 | 电压45dp | 负载42dp | 类型36dp | 告警时间48dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#1a1a2e"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="2dp">

    <!-- 序号 -->
    <TextView
        android:id="@+id/tvIndex"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="#505070"
        android:textSize="10sp"
        android:gravity="center"/>

    <!-- 站点名称（自适应） -->
    <TextView
        android:id="@+id/tvStName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="站点名称"
        android:textColor="#ffffff"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="3dp"/>

    <!-- 电压（固定46dp，右对齐） -->
    <TextView
        android:id="@+id/tvDcVoltage"
        android:layout_width="46dp"
        android:layout_height="wrap_content"
        android:text="0.00V"
        android:textColor="#e94560"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="end"
        android:layout_marginStart="3dp"/>

    <!-- 负载电流（固定44dp，右对齐） -->
    <TextView
        android:id="@+id/tvDcLoadCurrent"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:text="0.00A"
        android:textColor="#40c080"
        android:textSize="10sp"
        android:gravity="end"
        android:layout_marginStart="3dp"/>

    <!-- 类型（固定36dp，居中） -->
    <TextView
        android:id="@+id/tvCause"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:text="停电"
        android:textColor="#ffa500"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginStart="3dp"/>

    <!-- 告警时间（固定100dp，右对齐，不换行） -->
    <TextView
        android:id="@+id/tvAlarmTime"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="时间"
        android:textColor="#606080"
        android:textSize="8sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center_vertical|end"
        android:includeFontPadding="false"
        android:layout_marginStart="3dp"/>

    <!-- 站点编码（隐藏） -->
    <TextView
        android:id="@+id/tvStCode"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- 分组（隐藏） -->
    <TextView
        android:id="@+id/tvGroup"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</LinearLayout>
