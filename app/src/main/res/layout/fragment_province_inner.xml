<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 查询控制面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@android:color/white"
        android:layout_marginTop="6dp">

        <!-- 第一行：站名搜索 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etSearchStation"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="输入站名搜索"
                android:textSize="12sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/bg_spinner"
                android:singleLine="true" />

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:text="定位"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#10B981"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- 第二行：小组选择 + 工单类型 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="小组:"
                android:textSize="13sp"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinnerPIGroup"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="类型:"
                android:textSize="13sp"
                android:textColor="#333333"
                android:layout_marginStart="10dp" />

            <Spinner
                android:id="@+id/spinnerPIOrderType"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />
        </LinearLayout>

        <!-- 第三行：区县 + 处理人 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="区县:"
                android:textSize="13sp"
                android:textColor="#333333" />

            <Spinner
                android:id="@+id/spinnerPICounty"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="人员:"
                android:textSize="13sp"
                android:textColor="#333333"
                android:layout_marginStart="10dp" />

            <Spinner
                android:id="@+id/spinnerPIPerson"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_spinner"
                android:padding="6dp" />
        </LinearLayout>

        <!-- 第四行：排序按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序:"
                android:textSize="12sp"
                android:textColor="#666666" />

            <Button
                android:id="@+id/btnSortStation"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="站名"
                android:textSize="10sp"
                android:textColor="#333333"
                android:backgroundTint="#E5E7EB"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnSortTime"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="完成时间"
                android:textSize="10sp"
                android:textColor="#333333"
                android:backgroundTint="#E5E7EB"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnSortType"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="工单类型"
                android:textSize="10sp"
                android:textColor="#333333"
                android:backgroundTint="#E5E7EB"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- 第五行：查询按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPIQuery"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="我的待办"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#2563EB"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- 状态栏 -->
    <TextView
        android:id="@+id/tvPIStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="就绪，请选择小组后点击查询"
        android:textSize="11sp"
        android:textColor="#2563EB"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="#EFF6FF" />

    <!-- 工单列表（占主体空间） -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProvinceInnerOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

</LinearLayout>
