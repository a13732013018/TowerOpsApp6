<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 查询控制面板 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 站名搜索行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/etSearchStation"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:hint="输入站名快速查找"
                    android:textSize="12sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_spinner"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btnSearch"
                    android:layout_width="64dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="6dp"
                    android:text="查找"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_success"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 小组 + 类型 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小组"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:minWidth="28dp" />

                <Spinner
                    android:id="@+id/spinnerPIGroup"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_spinner"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="类型"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"
                    android:minWidth="28dp" />

                <Spinner
                    android:id="@+id/spinnerPIOrderType"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_spinner"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- 区县 + 人员 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="区县"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:minWidth="28dp" />

                <Spinner
                    android:id="@+id/spinnerPICounty"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_spinner"
                    android:padding="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="人员"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"
                    android:minWidth="28dp" />

                <Spinner
                    android:id="@+id/spinnerPIPerson"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_spinner"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp" />

            <!-- 查询按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnPIQuery"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="我的待办"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnToSignQuery"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="待签工单"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_city_audit"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnRandomPlan"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="随机上站"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_btn_county_audit"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 排序按钮行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="排序:"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnSortStation"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="站名"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:background="@drawable/bg_sort_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="3dp" />

                <Button
                    android:id="@+id/btnSortTime"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="时间"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:background="@drawable/bg_sort_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="3dp" />

                <Button
                    android:id="@+id/btnSortType"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="类型"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:background="@drawable/bg_sort_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="3dp" />

                <Button
                    android:id="@+id/btnSortCount"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="数量"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:background="@drawable/bg_sort_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="3dp" />

                <Button
                    android:id="@+id/btnSortHandler"
                    android:layout_width="0dp"
                    android:layout_height="26dp"
                    android:layout_weight="1"
                    android:text="接单人"
                    android:textSize="10sp"
                    android:textColor="#374151"
                    android:background="@drawable/bg_sort_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvPIStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪"
            android:textSize="11sp"
            android:textColor="#2563EB" />

        <TextView
            android:id="@+id/tvPICount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="共 0 条"
            android:textSize="11sp"
            android:textColor="#6B7280" />
    </LinearLayout>

    <!-- 工单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProvinceInnerOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

</LinearLayout>
