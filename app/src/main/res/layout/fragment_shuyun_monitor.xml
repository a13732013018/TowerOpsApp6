<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <!-- ══════════════════════════════════════════
         顶部品牌面板标题条  (绿色·数运监控主题)
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_panel_header">

        <!-- 左侧绿色强调竖线 -->
        <View
            android:layout_width="3dp"
            android:layout_height="18dp"
            android:background="#059669"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="数运监控"
            android:textSize="12sp"
            android:textColor="#1D4ED8"
            android:textStyle="bold" />

        <!-- 状态胶囊 -->
        <TextView
            android:id="@+id/tvShuyunStatus"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text="● 未启动"
            android:textSize="10sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:background="@drawable/bg_tag_inactive"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textSize="10sp"
            android:textColor="#6B7280"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待: 0"
            android:textSize="10sp"
            android:textColor="#2563EB"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tvProcessingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理: 0"
            android:textSize="10sp"
            android:textColor="#059669"
            android:textStyle="bold"
            android:layout_marginEnd="10dp" />
    </LinearLayout>

    <!-- ══════════════════════════════════════════
         登录面板 (CardView)
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 登录面板标题条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F0FDF4">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#059669"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账号登录"
                    android:textSize="10sp"
                    android:textColor="#059669"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- 第一行：PC验证码 -->
                <LinearLayout
                    android:id="@+id/layoutPcCaptcha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PC验证码"
                        android:textSize="11sp"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        android:minWidth="52dp" />

                    <ImageView
                        android:id="@+id/imgPcCaptcha"
                        android:layout_width="72dp"
                        android:layout_height="26dp"
                        android:layout_marginStart="6dp"
                        android:background="#F3F4F6"
                        android:scaleType="fitCenter"
                        android:contentDescription="验证码" />

                    <EditText
                        android:id="@+id/etPcCaptcha"
                        android:layout_width="52dp"
                        android:layout_height="26dp"
                        android:layout_marginStart="4dp"
                        android:hint="输入"
                        android:textSize="11sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:inputType="text"
                        android:maxLength="4"
                        android:gravity="center" />

                    <Button
                        android:id="@+id/btnRefreshCaptcha"
                        android:layout_width="32dp"
                        android:layout_height="26dp"
                        android:text="刷"
                        android:textSize="9sp"
                        android:background="@drawable/bg_button_gray"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="2dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />

                    <TextView
                        android:id="@+id/tvPcLoginStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="未登录"
                        android:textSize="10sp"
                        android:textColor="#EF4444"
                        android:gravity="center"
                        android:layout_marginStart="4dp" />

                    <Button
                        android:id="@+id/btnPcLogin"
                        android:layout_width="52dp"
                        android:layout_height="26dp"
                        android:text="PC登录"
                        android:textSize="9sp"
                        android:background="@drawable/bg_btn_success"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="2dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- 第二行：APP登录 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APP账号"
                        android:textSize="11sp"
                        android:textColor="#374151"
                        android:textStyle="bold"
                        android:minWidth="52dp" />

                    <Spinner
                        android:id="@+id/spinnerAppAccount"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:dropDownWidth="140dp" />

                    <TextView
                        android:id="@+id/tvImei"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IMEI:-"
                        android:textSize="9sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginStart="4dp"
                        android:maxWidth="56dp"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvAppLoginStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未登录"
                        android:textSize="10sp"
                        android:textColor="#EF4444"
                        android:layout_marginStart="4dp" />

                    <Button
                        android:id="@+id/btnAppLogin"
                        android:layout_width="52dp"
                        android:layout_height="26dp"
                        android:text="APP登录"
                        android:textSize="9sp"
                        android:background="@drawable/bg_button_primary_gradient"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="4dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         控制面板 (CardView)
    ══════════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="5dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 控制面板标题条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_panel_header">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#059669"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="监控控制"
                    android:textSize="10sp"
                    android:textColor="#1D4ED8"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="› 自动接单·自动回单"
                    android:textSize="9sp"
                    android:textColor="#6B7280"
                    android:layout_marginEnd="10dp" />
            </LinearLayout>

            <!-- 控制内容 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/cbAutoAccept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动接单"
                    android:textSize="12sp"
                    android:textColor="#1F2937"
                    android:checked="true"
                    android:minHeight="0dp" />

                <CheckBox
                    android:id="@+id/cbAutoRevert"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动回单"
                    android:textSize="12sp"
                    android:textColor="#1F2937"
                    android:checked="true"
                    android:layout_marginStart="12dp"
                    android:minHeight="0dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="区县"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:layout_marginStart="12dp" />

                <Spinner
                    android:id="@+id/spinnerCounty"
                    android:layout_width="80dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:dropDownWidth="120dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btnStartShuyun"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="启动监控"
                    android:textSize="11sp"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:textColor="@android:color/white"
                    android:minWidth="70dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnStopShuyun"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="停止"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_danger"
                    android:textColor="@android:color/white"
                    android:layout_marginStart="6dp"
                    android:minWidth="50dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:stateListAnimator="@null"
                    android:enabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══════════════════════════════════════════
         Tab 切换：待处理 | 处理中
    ══════════════════════════════════════════ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutShuyun"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:background="#FFFFFF"
        android:layout_marginTop="5dp"
        android:elevation="1dp"
        app:tabIndicatorColor="#059669"
        app:tabSelectedTextColor="#059669"
        app:tabTextColor="#6B7280"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabTextStyle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中" />
    </com.google.android.material.tabs.TabLayout>

    <!-- ══════════════════════════════════════════
         列表区域
    ══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="2dp">

        <!-- 待处理列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPending"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <!-- 处理中列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProcessing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- 空状态 -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:visibility="gone" />
    </FrameLayout>

    <!-- ══════════════════════════════════════════
         终端风日志区域
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:orientation="vertical"
        android:background="#0D1117"
        android:layout_marginTop="2dp">

        <!-- 日志标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#161B22"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- macOS 三点 -->
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="#FF5F57"
                android:layout_marginEnd="4dp" />
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="#FFBD2E"
                android:layout_marginEnd="4dp" />
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="#27C840"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="monitor.log"
                android:textSize="10sp"
                android:textColor="#8B949E"
                android:fontFamily="monospace" />

            <!-- LIVE 指示 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:text="● LIVE"
                android:textSize="8sp"
                android:textColor="#3FB950"
                android:gravity="center"
                android:background="@drawable/bg_live_indicator"
                android:paddingStart="5dp"
                android:paddingEnd="5dp" />
        </LinearLayout>

        <!-- 日志内容 -->
        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#C9D1D9"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
