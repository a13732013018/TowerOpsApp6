<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 登录面板 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账号登录"
                android:textSize="12sp"
                android:textColor="#1D4ED8"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- PC验证码行 -->
            <LinearLayout
                android:id="@+id/layoutPcCaptcha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="PC验证码"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgPcCaptcha"
                    android:layout_width="80dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:background="#F3F4F6"
                    android:scaleType="fitCenter"
                    android:contentDescription="验证码" />

                <EditText
                    android:id="@+id/etPcCaptcha"
                    android:layout_width="60dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:hint="输入"
                    android:textSize="12sp"
                    android:background="@drawable/bg_edittext"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:inputType="text"
                    android:maxLength="4"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btnRefreshCaptcha"
                    android:layout_width="36dp"
                    android:layout_height="30dp"
                    android:text="刷新"
                    android:textSize="9sp"
                    android:background="@drawable/bg_button_gray"
                    android:textColor="@android:color/white"
                    android:layout_marginStart="4dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/tvPcLoginStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未登录"
                    android:textSize="11sp"
                    android:textColor="#EF4444"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btnPcLogin"
                    android:layout_width="64dp"
                    android:layout_height="30dp"
                    android:text="PC登录"
                    android:textSize="11sp"
                    android:background="@drawable/bg_btn_success"
                    android:textColor="@android:color/white"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- APP账号行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="APP账号"
                    android:textSize="12sp"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerAppAccount"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp" />

                <TextView
                    android:id="@+id/tvImei"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMEI:-"
                    android:textSize="9sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginStart="6dp"
                    android:maxWidth="52dp"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvAppLoginStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未登录"
                    android:textSize="11sp"
                    android:textColor="#EF4444"
                    android:layout_marginStart="6dp" />

                <Button
                    android:id="@+id/btnAppLogin"
                    android:layout_width="64dp"
                    android:layout_height="30dp"
                    android:text="APP登录"
                    android:textSize="11sp"
                    android:background="@drawable/bg_button_primary_gradient"
                    android:textColor="@android:color/white"
                    android:layout_marginStart="6dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 控制面板 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbAutoAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动接单"
                android:textSize="12sp"
                android:textColor="#1F2937"
                android:checked="true"
                android:minHeight="0dp" />

            <CheckBox
                android:id="@+id/cbAutoRevert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动回单"
                android:textSize="12sp"
                android:textColor="#1F2937"
                android:checked="true"
                android:layout_marginStart="12dp"
                android:minHeight="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="区县"
                android:textSize="12sp"
                android:textColor="#374151"
                android:layout_marginStart="12dp" />

            <Spinner
                android:id="@+id/spinnerCounty"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <Button
                android:id="@+id/btnStartShuyun"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:text="启动"
                android:textSize="12sp"
                android:background="@drawable/bg_button_primary_gradient"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnStopShuyun"
                android:layout_width="56dp"
                android:layout_height="34dp"
                android:text="停止"
                android:textSize="12sp"
                android:background="@drawable/bg_btn_danger"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:enabled="false" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#FFFFFF"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvShuyunStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 未启动"
            android:textSize="11sp"
            android:textColor="#6B7280" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待:"
            android:textSize="11sp"
            android:textColor="#6B7280" />

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="11sp"
            android:textColor="#2563EB"
            android:textStyle="bold"
            android:layout_marginStart="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  处理:"
            android:textSize="11sp"
            android:textColor="#6B7280" />

        <TextView
            android:id="@+id/tvProcessingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="11sp"
            android:textColor="#059669"
            android:textStyle="bold"
            android:layout_marginStart="2dp" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:fontFamily="monospace"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Tab切换 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutShuyun"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:background="#FFFFFF"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#2563EB"
        app:tabTextColor="#6B7280"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabTextStyle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中" />
    </com.google.android.material.tabs.TabLayout>

    <!-- 列表区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPending"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProcessing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:visibility="gone" />
    </FrameLayout>

    <!-- 日志区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:orientation="vertical"
        android:background="#1E293B">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="#0F172A">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="运行日志"
                android:textSize="10sp"
                android:textColor="#64748B"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvShuyunStatus2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textSize="9sp"
                android:textColor="#22C55E" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="#94A3B8"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.3" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
