<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- 状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvShuyunStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="数运监控未启动"
            android:textSize="14sp"
            android:textColor="#333333"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--:--"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:fontFamily="monospace"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理: 0"
            android:textSize="13sp"
            android:textColor="#2563EB"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvProcessingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中: 0"
            android:textSize="13sp"
            android:textColor="#10B981" />
    </LinearLayout>

    <!-- 登录面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@android:color/white"
        android:layout_marginTop="1dp">

        <!-- 第一行：PC验证码 -->
        <LinearLayout
            android:id="@+id/layoutPcCaptcha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="验证码"
                android:textSize="12sp"
                android:textColor="#666666" />

            <ImageView
                android:id="@+id/imgPcCaptcha"
                android:layout_width="72dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:background="#F3F4F6"
                android:scaleType="fitCenter"
                android:contentDescription="验证码" />

            <EditText
                android:id="@+id/etPcCaptcha"
                android:layout_width="56dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:hint="验证码"
                android:textSize="11sp"
                android:background="@drawable/bg_edittext"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:inputType="text"
                android:maxLength="4"
                android:gravity="center" />

            <Button
                android:id="@+id/btnRefreshCaptcha"
                android:layout_width="36dp"
                android:layout_height="24dp"
                android:text="刷"
                android:textSize="10sp"
                android:backgroundTint="#6B7280"
                android:textColor="@android:color/white"
                android:layout_marginStart="2dp"
                android:minWidth="28dp"
                android:minHeight="0dp"
                android:padding="0dp" />

            <TextView
                android:id="@+id/tvPcLoginStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未登录"
                android:textSize="10sp"
                android:textColor="#EF4444"
                android:layout_marginStart="6dp" />

            <Button
                android:id="@+id/btnPcLogin"
                android:layout_width="48dp"
                android:layout_height="24dp"
                android:text="登录"
                android:textSize="10sp"
                android:backgroundTint="#10B981"
                android:textColor="@android:color/white"
                android:layout_marginStart="2dp"
                android:minWidth="36dp"
                android:minHeight="0dp"
                android:padding="0dp" />
        </LinearLayout>

        <!-- 第二行：APP登录 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP"
                android:textSize="12sp"
                android:textColor="#666666" />

            <Spinner
                android:id="@+id/spinnerAppAccount"
                android:layout_width="100dp"
                android:layout_height="26dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:dropDownWidth="140dp" />

            <TextView
                android:id="@+id/tvImei"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMEI:-"
                android:textSize="9sp"
                android:textColor="#9CA3AF"
                android:layout_marginStart="4dp"
                android:maxWidth="60dp"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvAppLoginStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未登录"
                android:textSize="10sp"
                android:textColor="#EF4444"
                android:layout_marginStart="4dp" />

            <Button
                android:id="@+id/btnAppLogin"
                android:layout_width="52dp"
                android:layout_height="26dp"
                android:text="登录"
                android:textSize="10sp"
                android:backgroundTint="#2563EB"
                android:textColor="@android:color/white"
                android:layout_marginStart="4dp"
                android:minWidth="40dp"
                android:minHeight="0dp"
                android:padding="0dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 控制面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@android:color/white"
        android:layout_marginTop="1dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbAutoAccept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动接单"
            android:textSize="12sp"
            android:checked="true"
            android:minHeight="0dp" />

        <CheckBox
            android:id="@+id/cbAutoRevert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动回单"
            android:textSize="12sp"
            android:checked="true"
            android:layout_marginStart="12dp"
            android:minHeight="0dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnStartShuyun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="启动监控"
            android:textSize="12sp"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"
            android:minWidth="70dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <Button
            android:id="@+id/btnStopShuyun"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="停止"
            android:textSize="12sp"
            android:backgroundTint="#EF4444"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp"
            android:minWidth="56dp"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Tab 切换：待处理 | 处理中 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutShuyun"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@android:color/white"
        android:layout_marginTop="1dp"
        app:tabIndicatorColor="#2563EB"
        app:tabSelectedTextColor="#2563EB"
        app:tabTextColor="#666666"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/TabTextStyle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待处理" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="处理中" />

    </com.google.android.material.tabs.TabLayout>

    <!-- 列表区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="1dp">

        <!-- 待处理列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPending"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <!-- 处理中列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProcessing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- 空状态 -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无数据"
            android:textSize="14sp"
            android:textColor="#999999"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 日志区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:background="#1F2937"
        android:layout_marginTop="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="运行日志"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:background="#111827" />

        <ScrollView
            android:id="@+id/svLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#E5E7EB"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.2" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
